                                <span className="text-[#45b7ff] transform rotate-3 origin-bottom translate-y-1" style={{ textShadow: "0 2px 0 #2a98db, 0 4px 0 #167cb8, 0 6px 0 #0a6397, 0 12px 12px rgba(0,0,0,0.3)" }}>I</span>
